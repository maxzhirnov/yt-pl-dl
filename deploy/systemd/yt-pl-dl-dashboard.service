[Unit]
Description=yt-pl-dl dashboard
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/yt-pl-dl
Environment=DENO_INSTALL=/root/.deno
Environment=PYTHONPATH=/opt/yt-pl-dl/src
Environment=PATH=/root/.deno/bin:/opt/yt-pl-dl/.venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
ExecStart=/opt/yt-pl-dl/.venv/bin/python -m yt_pl_dl.dashboard
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
